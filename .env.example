# Copy this file to .env and fill in real values. NEVER put real secrets here —
# .env.example is a committed template; .env is gitignored.

# ---- AI providers (each provider falls back to mock when its key is empty) ----
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=

# ---- Football data ----
APIFOOTBALL_KEY=
MOCK_FOOTBALL=true

# ---- Infra ----
# Default points at the docker-compose Postgres. The demos/tests override this
# with a throwaway SQLite DB, so you don't need Postgres to see it run.
DATABASE_URL=postgresql+asyncpg://fifa:fifa@localhost:5432/fifa
REDIS_URL=redis://localhost:6379/0

# ---- Cost guard ----
DAILY_TOKEN_BUDGET=2000000

# ---- Publishing / distribution ----
# Safety: when true, auto-publish LOGS posts instead of calling platform APIs.
# Set to false (with real credentials below) to actually post.
PUBLISH_DRY_RUN=true
# Used in post captions for the pull-back loop (verify/play links).
PUBLIC_BASE_URL=http://localhost:3000
# LinkedIn (needs a LinkedIn app + posting token)
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AUTHOR_URN=          # e.g. urn:li:organization:123456 or urn:li:person:abc
# Meta — Facebook Page + Instagram Business share one Page token (App Review needed)
META_PAGE_ID=
META_PAGE_TOKEN=
INSTAGRAM_BUSINESS_ID=
# NOTE: YouTube is not wired — it needs a video asset, not an image card.

# ---- Commit-reveal ----
# Rotate per season, keep secret. Changing this invalidates all existing hashes.
COMMIT_SALT=dev-only-change-me

# ---- In-process scheduler (Docker-free alternative to Celery worker+beat) ----
# When true, the backend itself runs the scan->predict->lock->settle->publish
# cadence on a timer. No Redis/Celery/Docker needed.
RUN_SCHEDULER=false
SCHEDULER_INTERVAL_SECONDS=300
